{
  "name": "sbscoreboard",
  "productName": "BOA Scoreboard",
  "description": "BOA Scoreboard",
  "version": "2.0.0",
  "private": true,
  "author": "Jason Small <jason@sbx.agency.net>",
  "copyright": "© 2021, sbX LLC.",
  "homepage": "http://sbx.aency",
  "main": "app/background.js",
  "build": {
    "appId": "com.socialboothsyncv3",
    "win": {
      "signAndEditExecutable": false
    },
    "files": [
      "app/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "resources"
    },
    "extraResources": [
      "./extraResources/**"
    ],
    "publish": {
      "provider": "s3",
      "bucket": "app-bmw-scoreboard",
      "region": "us-east-1"
    }
  },
  "scripts": {
    "postinstall": "patch-package && electron-builder install-app-deps",
    "preunit": "webpack --config=build/webpack.unit.config.js --env=test --stats=none",
    "unit": "electron-mocha temp/specs.js --renderer --require source-map-support/register",
    "pree2e": "webpack --config=build/webpack.app.config.js --env=test --stats=none && webpack --config=build/webpack.e2e.config.js --env=test --stats=none",
    "e2e": "mocha temp/e2e.js --require source-map-support/register",
    "test": "npm run unit",
    "start": "node build/start.js",
    "copy": "node build/copy.js",
    "release": "npm test && webpack --config=build/webpack.app.config.js --env=production && electron-builder"
  },
  "dependencies": {
    "@electron/remote": "^2.1.2",
    "async": "^2.6.1",
    "bootstrap": "^4.1.0",
    "bufferutil": "^4.0.1",
    "ejs": "^3.0.2",
    "electron-contextmenu-middleware": "^1.0.3",
    "electron-input-menu": "^2.1.0",
    "electron-json-storage": "^4.6.0",
    "electron-log": "^2.2.14",
    "electron-updater": "^6.3.4",
    "express": "^4.17.1",
    "faker": "^5.5.3",
    "fluent-ffmpeg": "^2.1.2",
    "fs-extra": "^8.1.0",
    "fs-jetpack": "^1.0.0",
    "graceful-fs": "^4.2.3",
    "jquery": "^3.3.1",
    "mime-types": "^2.1.27",
    "moment": "^2.22.2",
    "nedb": "^1.8.0",
    "popper.js": "^1.14.3",
    "request": "^2.88.0",
    "sharp": "^0.33.0",
    "socket.io": "^4.5.4",
    "sweetalert2": "^9.10.12",
    "underscore": "^1.13.1",
    "utf-8-validate": "^5.0.2"
  },
  "overrides": {
    "nan": "^2.22.0",
    "node-abi": "^4.27.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "babel-loader": "^9.1.3",
    "chai": "^4.4.1",
    "css-loader": "^6.10.0",
    "electron": "33.2.1",
    "electron-builder": "^24.13.3",
    "electron-mocha": "^12.0.0",
    "mocha": "^10.4.0",
    "patch-package": "^8.0.1",
    "source-map-support": "^0.5.21",
    "style-loader": "^3.3.4",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-merge": "^5.10.0",
    "webpack-node-externals": "^3.0.0"
  }
}
