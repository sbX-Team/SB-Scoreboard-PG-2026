<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">

    <title>BOA Scoreboard</title>
    <link rel="stylesheet" href="./expressassets/css/bootstrap.min.css">
    <style>
        @font-face {
    font-family: 'Connections';
    src: url('./fonts/Connections.woff2') format('woff2'),
        url('./fonts/Connections.woff') format('woff');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
}


        body {
            cursor: none;
           
            
        }
        #connectionError {
            position: absolute;
            bottom: 0px;
            right: 0px;
            width: 100px;
            display: none;
        }
        #leaderboard {
            height: 1080px;
            width: 1920px;
            overflow: hidden;
            /* font-weight: 500; */
            /* display: none;
             */
            background-image: url('./expressassets/images/leaderboard.png');
            position: absolute;
            top:0px;
            left:0px;
        }
        #newScore {
            display: none;
            position: absolute;
            top: 0px;
            left: 0px;
            z-index: 10001;
            background-color: #122048;
            color: #fff;
            background-image: url('./expressassets/images/newscore.png');
            background-size: cover;
            font-weight: 500;
            height:1080px;
            width:1920px;
        }
        #header {
            height: 330px;
            text-align: center;
            position: absolute;
            top: 0px;
            left: 0px;
            width: 1080px;
        }
        #logo {
            margin: auto;
            z-index: 10000;
            position: absolute;
            top: 0px;
            left: 0px;
        }
        #footer {
            margin: auto;
            z-index: 10000;
            position: absolute;
            bottom: 0px;
            left: 0px;
        }
        #tableHeader {
            z-index: 10000;
            position: absolute;
            top: -11px;
            left: 0px;
        }
        .table {
            font-size: 67px;
            border-bottom: #6f6f6f;
            margin-top: 333px;
            width: 80%;
            margin: auto;
        }
        .table td {
            padding-top: 14px;
            padding-bottom: 14px;
            border-bottom: 3px solid #6f6f6f;
            color: #6f6f6f;
        }
        .table th {
            padding-top: 50px;
            padding-bottom: 50px;
            background-color: #afabc9;
            border: 3px solid #7c6992;
            color: #6f6f6f;
        }
        .superscript { position: relative; top: -0.5em; font-size: 80%; }
        .place {
            text-align: left;
            border-left: 0px !important;
            width: 30px;
        }
        .name {
            padding-left: 10px !important;
            width: 440px !important;
            text-align: left;
            overflow: hidden !important;
        }
        .score {
            text-align: right;
            border-right: 0px !important;
            width: 340px;
        }
        .table thead th { border-top: 0px !important; }
        #scoreboard { margin-top: 200px; }
        /* #newScore {
            opacity: 1;
            display: block;
            position: absolute;
            top: 0px;
            left: 0px;
            z-index: 10001;
            background-color: #122048;
            color: #fff;
            background-size: cover;
            font-family: "BMWTypeNext Pro";
            font-weight: 500;
        } */
        #square { position: absolute; bottom: -1140px; }
        #mascott { position: absolute; bottom: -10px; left: -1238px; }
        #newName {
            position: relative;
            top: 259px;
            font-size: 165px;
            opacity: 0;
            color: #fff;
            margin: auto;
            text-align: center;
        }
        #newScoreArea {
            position: absolute;
            top: 588px;
            left: 0;
            font-size: 264px;
            color: #06205c;
            opacity: 0;
            width: 1080px;
            text-align: center;
            line-height: 1;
        }
        #newScoreText {
               display: inline-block;
            color: #fff;
            position: absolute;
            left: 170px;
            top: 404px;
            font-size: 378px;
            width: 1594px;
            /* border: 1px solid; */
            text-align: center;
            font-family: 'Connections';
            font-weight: bold;
        }
        #pts {
            position: relative;
            top: -44px;
            font-size: 245px;
            display: block;
        }
        .table td, .table th {
            padding: 0.75rem;
            vertical-align: top;
            border-top: 0px solid #06205c;
        }
        #guageTop {
            height: 1128px;
            width: 1080px;
            position: absolute;
            background-image: url(./expressassets/images/top2026.png);
            background-size: contain;
            background-repeat: no-repeat;
            left: 400px;
            top: -21px;
        }
        #guageBottom {
            height: 1128px;
            width: 1080px;
            position: absolute;
            background-image: url(./expressassets/images/bottom2026.png);
            background-size: contain;
            background-repeat: no-repeat;
            background-color: #122048;
            left: 400px;
            top: -21px;
        }
        #color {
            background: #158ce5;
            width: 642px;
            height: 16px;
            position: absolute;
            bottom: 46px;
            left: 404px;
            -webkit-box-shadow: 1px 1px 3px 0 rgba(0, 0, 0, 0.5);
            box-shadow: 1px 1px 3px 0 rgba(0, 0, 0, 0.5);
        }
        #line {
            z-index: 1000;
            position: inherit;
            top: -14px;
            width: 215px;
            left: 460px;
        }
        .speedNumber {
            font-family: "BMWTypeNext";
            font-weight: 300;
            font-size: 55px;
            color: #fff;
        }
        #zero   { position: absolute; top: 965px; left: 620px; }
        #twenty { position: absolute; top: 853px; left: 562px; }
        #fourty { position: absolute; top: 742px; left: 488px; }
        #sixty  { position: absolute; top: 633px; left: 420px; }
        #eighty { position: absolute; top: 519px; left: 355px; }
        #onehundred  { position: absolute; top: 407px; left: 334px; }
        #onetwenty   { position: absolute; top: 296px; left: 429px; }
        #oneforty    { position: absolute; top: 184px; left: 532px; }
        #onesixty    { position: absolute; top: 73px;  left: 634px; }


        .leaderboardValue {
            color: #fff;
        }
        .leaderboardTable{
            /* border:1px solid #fff; */
            font-family: "Connections";
            font-size: 104px;

        }
        #leaderboard1 {
         position: absolute;
    top: 509px;
    left: 314px;
    width: 603px;
    line-height: 1.2;
        }
         #leaderboard2 {
              position: absolute;
    top: 509px;
    left: 972px;
    width: 603px;
    line-height: 1.2;
        }
        .place{
            width: 106px;
            text-align: right;

        }
        .initial{
            width: 190px;
            text-align: right;
            font-weight: bold;

        }
        /* .dash{
            width: 90px;
            text-align: center;
        } */
        .score{
            width: 210px;
            text-align: right;
            font-weight: bold;

        }
        #sbTakeover {
            display: none;
            position: absolute;
            top: 0; left: 0;
            z-index: 10002;
            width: 1920px; height: 1080px;
        }
        #sbTakeover img {
            width: 1920px; height: 1080px;
            object-fit: cover;
        }
        #newScoreName {
         position: absolute;
        top: 269px;
        left: 0;
        width: 1920px;
        text-align: center;
        font-size: 80px;
        color: #c41230;
        font-size: 127px;
        font-family: "Connections";
        font-weight: bold;
        text-transform: uppercase;
        }

    </style>
</head>

<body class='blue'>

    <div id='newScore'>
        <div id="newScoreName">
            J.S.'s Score
        </div>
        <div id="newScoreText">150</div>
    </div>

    <div id='sbTakeover'>
        <img src='/SB-Scoreboard/banking.png' />
    </div>

    <div id="leaderboard">
        <table class='leaderboardTable' id="leaderboard1">
            <tr>
                <td class='place leaderboardValue'>1.</td>
                <td class='initial leaderboardValue' id='initial1'>W</td>
                <td class='dash leaderboardValue' id='dash1'>-</td>
                <td class='score leaderboardValue' id='score1'>100</td>
            </tr>
            <tr>
         <td class='place leaderboardValue'>2.</td>
                <td class='initial leaderboardValue' id='initial2'>J</td>
                <td class='dash leaderboardValue' id='dash2'>-</td>
                <td class='score leaderboardValue' id='score2'>85</td>
            </tr>
            <tr>
                <td class='place leaderboardValue'>3.</td>
                <td class='initial leaderboardValue' id='initial3'>J</td>
                <td class='dash leaderboardValue' id='dash3'>-</td>
                <td class='score leaderboardValue' id='score3'>80</td>
            </tr>
        </table>
         <table class='leaderboardTable' id="leaderboard2">
            <tr>
                <td class='place leaderboardValue'>4.</td>
                <td class='initial leaderboardValue' id='initial1'>W</td>
                <td class='dash leaderboardValue' id='dash1'>-</td>
                <td class='score leaderboardValue' id='score1'>100</td>
            </tr>
            <tr>
         <td class='place leaderboardValue'>5.</td>
                <td class='initial leaderboardValue' id='initial2'>J</td>
                <td class='dash leaderboardValue' id='dash2'>-</td>
                <td class='score leaderboardValue' id='score2'>85</td>
            </tr>
            <tr>
                <td class='place leaderboardValue'>6.</td>
                <td class='initial leaderboardValue' id='initial3'>J</td>
                <td class='dash leaderboardValue' id='dash3'>-</td>
                <td class='score leaderboardValue' id='score3'>80</td>
            </tr>
        </table>

        <!-- <table class='leaderboardTable' id="leaderboard1"></table>
         <table class='leaderboardTable' id="leaderboard2"></table> -->




    </div>

    <img src='./expressassets/images/disconnected.png' id='connectionError' />

    <script>if (typeof module === 'object') { window.module = module; module = undefined; }</script>
    <script src="./expressassets/js/jquery-3.4.1.min.js"></script>
    <script src="./expressassets/js/popper.min.js"></script>
    <script src="./expressassets/js/bootstrap.min.js"></script>
    <script src="./expressassets/js/velocity.js"></script>
    <script src="./expressassets/js/velocity.ui.min.js"></script>
    <script>if (window.module) module = window.module;</script>
    <script src="./scoreboard.js"></script>
</body>
</html>
