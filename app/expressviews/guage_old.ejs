	<script>
	
	var ip = window.location.host
	console.log(ip)
    var socket = io(ip)
	var numScores = <%= scoreboard.length %>
	var speed = 90
	//963

	var maxHeight = 963
	if(speed <= 110){
		maxHeight = 990
	}

	if(speed <= 80){
		maxHeight = 1000
	}
	if(speed < 70){
		maxHeight = 1025
	}
	if(speed < 50){
		maxHeight = 1050
	}
	if(speed < 30){
		maxHeight = 1200
	}
	

	var height = map_range(speed, 0, 140, 0, maxHeight)
	var halfheight= map_range(80, 0, 140, 0, maxHeight)
	console.log(height)
	console.log(halfheight)
	var leftValue

	setTimeout(() => {
		var percentageChange = map_range(speed, 0, 80, 0, 100) 
		

		console.log(386 - (314 * (percentageChange / 100)))
		console.log(percentageChange)
		// leftValue = map_range((1519 - elements[0].offsetTop), 0, 550, 0, 80)
		$('#color').velocity({height:height}, {
			duration: 3000,
		 	easing: 'linear'
		})
		if(speed >= 80){
			var endLeft = 386 - (331 * (percentageChange / 100))
			$('#line').velocity({height:halfheight-45, left: 72}, {duration:1500, easing: 'linear',
				complete: function(){

					$('#line').velocity({height:height+10, left: endLeft}, {duration:1500, easing: 'linear'})
				}})
			
		}
		else{
			var endLeft = 386 - (331 * (percentageChange / 100))
			$('#line').velocity({height:height+10, left: endLeft}, {duration:3000, easing: 'linear'})
		}
		
	}, 3000);



	function map_range(value, low1, high1, low2, high2) {
    	return low2 + (high2 - low2) * (value - low1) / (high1 - low1);
	}

// setTimeout(() => {
